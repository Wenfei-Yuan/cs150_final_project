# Copy to .env and fill in your values

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="ADHD Reading Companion"
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://reading_user:reading_pass@localhost:5432/reading_companion

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ── Vector store ──────────────────────────────────────────────────────────────
# Options: chroma | faiss | pgvector
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=chroma_db

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_MAX_TOKENS=400
CHUNK_MAX_PARAGRAPHS=2

# ── Guardrails ────────────────────────────────────────────────────────────────
RETELL_MIN_CHARS=50
RETELL_MAX_COPY_RATIO=0.7
MAX_PDF_PAGES=100
