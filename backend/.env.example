# Copy to .env and fill in your values

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="ADHD Reading Companion"
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://reading_user:reading_pass@localhost:5432/reading_companion

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# ── LLM ───────────────────────────────────────────────────────────────────────
# Model name must be one supported by the school proxy:
#   4o-mini, gpt-4.1-mini, gpt-5-mini, gpt-5-nano,
#   us.meta.llama4-maverick-17b-instruct-v1:0, us.meta.llama3-3-70b-instruct-v1:0,
#   us.anthropic.claude-3-haiku-20240307-v1:0, gemini-2.5-flash-lite, etc.
OPENAI_MODEL=4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ── LLMProxy (school API) ─────────────────────────────────────────────────────
LLMPROXY_API_KEY=externalUserBasic-k9t4j4-KYq5iJ2g4BVhLXAwL7An1yG9wnX8GV7svjTd46K6
LLMPROXY_ENDPOINT=https://a061igc186.execute-api.us-east-1.amazonaws.com/prod

# ── Vector store ──────────────────────────────────────────────────────────────
# Options: chroma | faiss | pgvector
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=chroma_db

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_MAX_TOKENS=400
CHUNK_MAX_PARAGRAPHS=2

# ── Guardrails ────────────────────────────────────────────────────────────────
RETELL_MIN_CHARS=50
RETELL_MAX_COPY_RATIO=0.7
MAX_PDF_PAGES=100
